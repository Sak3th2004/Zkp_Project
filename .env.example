# =============================================================================
# ZKProofAPI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost:8000
DASHBOARD_URL=http://localhost:3000
WEBSITE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
APP_VERSION=1.0.0

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://zkp:zkp@localhost:5432/zkproofapi
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-64-char-random-string
JWT_SECRET=change-me-to-another-64-char-random-string
JWT_EXPIRY_HOURS=24
JWT_ALGORITHM=HS256
API_KEY_SALT=change-me-to-a-32-char-random-string

# ── Stripe (Billing) ────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── Email (optional) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Monitoring (optional) ───────────────────────────────────────────────────
SENTRY_DSN=
